@page "/dashboard"
@inject PortalApiClient Api

<PageTitle>Dashboard — Dialled In</PageTitle>

<h1>Dashboard</h1>
<p class="muted">Cold outreach, done properly. The portal is under construction.</p>

<div class="spacer"></div>

<div class="card" style="max-width: 420px;">
    @if (status is null)
    {
        <span class="pill">API: checking…</span>
    }
    else
    {
        <span class="pill ok"><span class="dot green"></span>API online</span>
        <div class="sub" style="margin-top: 0.5rem;">@status.Service v@(status.Version)</div>
    }
</div>

@code {
    private PortalStatus? status;

    protected override async Task OnInitializedAsync()
    {
        status = await Api.GetStatusAsync();
    }
}
